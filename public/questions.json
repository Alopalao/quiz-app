{
  "id": "q6",
  "type": "image_legend_dropdown",
  "prompt": "Identify the internal components of a laser printer labeled 1 through 12.",
  "image": {
    "src": "images/laser_printer_inside.jpg",
    "alt": "Internal components and paper path of a laser printer",
    "width": 600,
    "height": 530
  },
  "legends": [
    {
      "id": "paper_sensor",
      "marker": "1",
      "label": "Component 1",
      "hint": "Detects whether paper is loaded in the tray or if a paper feed error has occurred.",
      "options": ["Paper Sensor", "Registration Roller", "Transfer Roller", "Exit Roller"]
    },
    {
      "id": "opc_drum",
      "marker": "2",
      "label": "Component 2",
      "hint": "The central light-sensitive component that holds the electrostatic image drawn by the laser.",
      "options": ["Imaging Drum", "Developer Roller", "Fuser Roller", "Transfer Roller"]
    },
    {
      "id": "primary_charge_roller",
      "marker": "3",
      "label": "Component 3",
      "hint": "Applies a uniform negative charge to the surface of the imaging drum during the charging phase.",
      "options": ["Primary Charge Roller (PCR)", "Transfer Roller", "Cleaning Blade", "Laser Assembly"]
    },
    {
      "id": "laser_beam",
      "marker": "4",
      "label": "Component 4",
      "hint": "The light source responsible for exposing the drum and neutralizing specific charged areas.",
      "options": ["Laser Beam", "Corona Wire", "Transfer Roller", "HVPS Output"]
    },
    {
      "id": "scanning_mirror",
      "marker": "5",
      "label": "Component 5",
      "hint": "The internal optical mirror system that directs the laser beam across the imaging drum.",
      "options": ["Laser Scanning Assembly", "Fuser Unit", "Registration Guide", "Pickup Roller"]
    },
    {
      "id": "developer_roller",
      "marker": "6",
      "label": "Component 6",
      "hint": "Prepares and moves toner particles from the hopper onto the exposed areas of the imaging drum.",
      "options": ["Developing Roller", "Pickup Roller", "Separation Pad", "Transfer Roller"]
    },
    {
      "id": "toner_hopper",
      "marker": "7",
      "label": "Component 7",
      "hint": "The replaceable reservoir that holds the fine plastic-based powder used for printing.",
      "options": ["Toner Cartridge", "Waste Toner Container", "Fuser Assembly", "Paper Cassette"]
    },
    {
      "id": "pickup_rollers",
      "marker": "8",
      "label": "Component 8",
      "hint": "Picks up paper from the tray and feeds it into the printer.",
      "options": ["Registration Rollers", "Pickup Rollers", "Exit Rollers", "Duplexing Assembly"]
    },
    {
      "id": "paper_tray",
      "marker": "9",
      "label": "Component 9",
      "hint": "The removable physical tray where the blank paper stock is held.",
      "options": ["Paper Tray", "Output Bin", "Duplex Tray", "Bypass Slot"]
    },
    {
      "id": "transfer_roller",
      "marker": "10",
      "label": "Component 10",
      "hint": "Puts a strong positive charge on the back of the paper to pull toner off the drum.",
      "options": ["Transfer Roller", "Primary Charge Roller (PCR)", "Developing Roller", "Pickup Roller"]
    },
    {
      "id": "cleaning_blade",
      "marker": "11",
      "label": "Component 11",
      "hint": "Physically removes any residual toner dust left on the drum before the next printing cycle.",
      "options": ["Cleaning Blade", "Separation Pad", "Registration Roller", "Fuser Pressure Roller"]
    },
    {
      "id": "fuser_assembly",
      "marker": "12",
      "label": "Component 12",
      "hint": "Applies intense heat and pressure to permanently bond the loose toner into the paper fibers.",
      "options": ["Fuser Assembly", "Transfer Unit", "Developing Roller", "Duplex Assembly"]
    }
  ],
  "correct_answers": {
    "paper_sensor": "Paper Sensor",
    "opc_drum": "Imaging Drum",
    "primary_charge_roller": "Primary Charge Roller (PCR)",
    "laser_beam": "Laser Beam",
    "scanning_mirror": "Laser Scanning Assembly",
    "developer_roller": "Developing Roller",
    "toner_hopper": "Toner Cartridge",
    "pickup_rollers": "Pickup Rollers",
    "paper_tray": "Paper Tray",
    "transfer_roller": "Transfer Roller",
    "cleaning_blade": "Cleaning Blade",
    "fuser_assembly": "Fuser Assembly"
  }
},
{
  "id": "q8",
  "type": "table",
  "prompt": "Analyze each laser printer malfunction scenario and match it with the correct internal component responsible for the issue.",
  "columns": [
    { "id": "component", "label": "Component" },
    { "id": "scenario", "label": "The Scenario" }
  ],
  "rows": [
    {
      "id": "row_1",
      "hint": "The rubber wheels have become smooth, coated in paper dander, or worn down, losing the friction needed to grip the top sheet.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row1_component",
          "label": "Row 1 Component",
          "options": ["Pickup Rollers", "Separation Pads", "Registration Rollers", "Duplexing Assembly"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The printer sounds like it is trying to print, but the paper never leaves the tray. Alternatively, the printer reports it is out of paper even though the tray is completely full." 
        }
      ]
    },
    {
      "id": "row_2",
      "hint": "The separation pad’s high-friction surface has worn out, failing to hold back the lower sheets when the pickup roller spins.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row2_component",
          "label": "Row 2 Component",
          "options": ["Pickup Rollers", "Separation Pads", "Transfer Roller", "Fuser Assembly"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The printer tries to grab one piece of paper but accidentally pulls in 3 to 5 sheets at the exact same time, causing an immediate paper jam right as the paper leaves the tray." 
        }
      ]
    },
    {
      "id": "row_3",
      "hint": "The rollers are dirty, unevenly worn, or out of sync, releasing one side of the paper slightly faster than the other.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row3_component",
          "label": "Row 3 Component",
          "options": ["Separation Pads", "Registration Rollers", "Imaging Drum (OPC Drum)", "Cleaning Blade"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The paper feeds out of the tray fine, but the printed text is noticeably crooked on the page, or the paper consistently jams right before it goes under the imaging drum." 
        }
      ]
    },
    {
      "id": "row_4",
      "hint": "The photosensitive surface is physically scratched, damaged by light exposure, or electrically shorted.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row4_component",
          "label": "Row 4 Component",
          "options": ["Imaging Drum (OPC Drum)", "Primary Charge Roller (PCR)", "Developing Roller", "Transfer Belt"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "You get a completely blank white page, a completely jet-black page, or a perfectly straight, sharp line or scratch running all the way down every single page." 
        }
      ]
    },
    {
      "id": "row_5",
      "hint": "If the PCR fails to apply the uniform negative charge (-600V), toner will jump onto every square inch of the drum, drowning the page in black.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row5_component",
          "label": "Row 5 Component",
          "options": ["Imaging Drum (OPC Drum)", "Primary Charge Roller (PCR)", "Transfer Roller", "Cleaning Blade"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "A completely black page, or a repeating background defect that occurs at a mathematically precise interval down the page." 
        }
      ]
    },
    {
      "id": "row_6",
      "hint": "The roller cannot attract toner because the reservoir is empty, or toner has clumped together unevenly inside the hopper.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row6_component",
          "label": "Row 6 Component",
          "options": ["Primary Charge Roller (PCR)", "Developing Roller", "Transfer Roller", "Fuser Assembly"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The image prints out, but the text is incredibly light, or there are clean vertical white streaks running down the page where no ink applied at all." 
        }
      ]
    },
    {
      "id": "row_7",
      "hint": "The transfer roller isn't putting a positive charge on the back of the paper. Without that charge, the toner stays on the drum and refuses to jump onto the paper.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row7_component",
          "label": "Row 7 Component",
          "options": ["Developing Roller", "Transfer Roller", "Fuser Assembly", "Transfer Belt"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The printer goes through all the motions, but the paper comes out completely blank or with an image so faint you can barely see it. However, if you open the printer mid-cycle, you can see the toner sitting perfectly on the drum." 
        }
      ]
    },
    {
      "id": "row_8",
      "hint": "The fuser is not reaching its required melting temperature (approx. 180°C). The loose plastic resin particles are sitting on the paper but were never permanently melted into the fibers.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row8_component",
          "label": "Row 8 Component",
          "options": ["Registration Rollers", "Transfer Roller", "Fuser Assembly", "Cleaning Blade"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The text looks beautiful and crisp when it exits the printer, but the moment you touch the paper, the toner wipes completely off on your fingers like loose charcoal dust." 
        }
      ]
    },
    {
      "id": "row_9",
      "hint": "The rubber scraper blade is nicked or worn out, failing to physically wipe away residual toner left over from the last rotation of the drum.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row9_component",
          "label": "Row 9 Component",
          "options": ["Primary Charge Roller (PCR)", "Fuser Assembly", "Cleaning Blade", "Transfer Belt"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "You print a page with a large bold header at the top. Further down the page (or on the next page), you see a faint, blurry 'ghost' echo of that exact same header." 
        }
      ]
    },
    {
      "id": "row_10",
      "hint": "The mechanical gears or reversing rollers responsible for grabbing the sheet at the exit slot and pulling it backward down the return track are broken or obstructed.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row10_component",
          "label": "Row 10 Component",
          "options": ["Pickup Rollers", "Registration Rollers", "Duplexing Assembly", "Transfer Belt"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "The printer works perfectly when printing normal 1-page documents. The second you select 'Print on Both Sides,' the paper jams immediately after passing through the fuser." 
        }
      ]
    },
    {
      "id": "row_11",
      "hint": "The multi-stage transfer belt is slipping or failing to sync with the individual color drums.",
      "cells": [
        {
          "columnId": "component",
          "type": "dropdown",
          "fieldId": "row11_component",
          "label": "Row 11 Component",
          "options": ["Imaging Drum (OPC Drum)", "Developing Roller", "Duplexing Assembly", "Transfer Belt"]
        },
        { 
          "columnId": "scenario", 
          "type": "text", 
          "value": "You print a color photo, but the cyan, magenta, and yellow layers don't line up correctly, making the image look blurry, misaligned, or giving it a 3D-glasses effect." 
        }
      ]
    }
  ],
  "correct_answers": {
    "row1_component": "Pickup Rollers",
    "row2_component": "Separation Pads",
    "row3_component": "Registration Rollers",
    "row4_component": "Imaging Drum (OPC Drum)",
    "row5_component": "Primary Charge Roller (PCR)",
    "row6_component": "Developing Roller",
    "row7_component": "Transfer Roller",
    "row8_component": "Fuser Assembly",
    "row9_component": "Cleaning Blade",
    "row10_component": "Duplexing Assembly",
    "row11_component": "Transfer Belt"
  }
}
  ]
}
